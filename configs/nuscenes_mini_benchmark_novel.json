{
  "benchmark": {
    "name": "nuscenes_mini_domain_shift_benchmark_counterfactual_consensus",
    "seed": 11,
    "calibration_bins": 10,
    "fusion_method": "counterfactual_consensus",
    "evidence_power": 1.6,
    "agreement_gamma": 2.2,
    "counterfactual_beta": 6.5
  },
  "dataset": {
    "source": "sqlite",
    "db_path": "data/nuscenes_mini_samples.db",
    "table": "samples",
    "limit": 404
  },
  "scenarios": [
    {
      "name": "baseline",
      "description": "No perturbations",
      "operations": []
    },
    {
      "name": "weather_and_occlusion_shift",
      "description": "Camera quality drop and radar/lidar stress under adverse conditions",
      "operations": [
        { "type": "gaussian_noise", "target": "camera", "std": 0.09 },
        { "type": "dropout", "target": "lidar", "probability": 0.10 },
        { "type": "bias_drift", "target": "radar", "offset": -0.05 },
        { "type": "uncertainty_inflation", "target": "all", "factor": 1.2 }
      ]
    }
  ]
}
